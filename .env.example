# Environment Configuration

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production-to-strong-random-value
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - SQLite (default for development)
# For PostgreSQL, set USE_POSTGRES=True and configure below
USE_POSTGRES=False

# PostgreSQL Configuration (if USE_POSTGRES=True)
DB_NAME=jobboard
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Elasticsearch
ELASTICSEARCH_HOST=localhost:9200

# Redis & Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Email Configuration
# Use 'django.core.mail.backends.console.EmailBackend' for development
# Use 'django.core.mail.backends.smtp.EmailBackend' for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@jobboard.com

# File Upload
MAX_RESUME_SIZE=5242880  # 5MB in bytes

# Pagination
ITEMS_PER_PAGE=20
MAX_PAGE_SIZE=100

# JWT Configuration (already in settings.py, shown for reference)
# JWT_SECRET_KEY will use SECRET_KEY if not provided
# ACCESS_TOKEN_LIFETIME=3600  # 1 hour in seconds
# REFRESH_TOKEN_LIFETIME=604800  # 7 days in seconds
